# .gitignore v2

##################################################
# OS / Editor
##################################################
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

##################################################
# Arduino build artifacts
##################################################
*.hex
*.elf
*.bin
*.eep
*.map

# Arduino CLI / IDE temp build dirs
/build/
build/
*.arduino.*
*.core.a

# Doxygen derivatives
/docs/doxygen/*

##################################################
# Host test / Makefile builds
##################################################
/build*/
*.o
*.a
*.so
*.dylib
*.exe

##################################################
# Coverage / test artifacts
##################################################
*.gcno
*.gcda
*.gcov
coverage/
*.profraw
*.profdata

##################################################
# Logs / temp
##################################################
*.log
*.tmp

##################################################
# Keep source of truth
##################################################
# DO NOT ignore:
# - src/
# - extras/host_test/
# - *.ino
# - Makefile